{
  "name": "@hanzo/skill",
  "version": "1.0.1",
  "description": "Install and manage AI agent skills — ~/.hanzo/skills/ as canonical source, symlinked to all agents",
  "keywords": ["ai", "agents", "skills", "mcp", "claude", "cursor", "codex", "hanzo"],
  "license": "MIT",
  "author": "Hanzo AI <hello@hanzo.ai>",
  "repository": {
    "type": "git",
    "url": "https://github.com/hanzoai/skill.git"
  },
  "homepage": "https://hanzo.ai",
  "type": "module",
  "bin": {
    "hanzo-skill": "dist/cli.js",
    "skill": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
